# SuperHydra development environment
# Copy to .env (gitignored) and customize as needed
# This file is committed; .env is not
POSTGRES_DB=superhydra
POSTGRES_USER=superhydra
POSTGRES_PASSWORD=superhydra_dev_only
# Connection string for application code
DATABASE_URL=postgresql://superhydra:superhydra_dev_only@localhost:5432/superhydra
